{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "noEmit": true,
        "verbatimModuleSyntax": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "cSpell.enableFiletypes": {
  "typescript": false,
  "javascript": false
        },

        "types": [
            "node",
            "vitest/globals"
        ],
        "rootDir": "./src"
    },
    "include": [
        "src/**/*.ts"
    ]
}
